# 环境变量配置
# 复制此文件为 .env 并修改相应配置

# 相机配置
CAMERA_ID=0
RESOLUTION=1920x1080
FPS=20

# 检测配置
CONF_THRESHOLD=0.5
IOU_THRESHOLD=0.45
SMOOTH_ENABLED=true

# 空间计量配置
REF_SHOULDER_WIDTH=0.45
CAMERA_HEIGHT=1.8
PITCH_ANGLE=30.0
TOPVIEW_SCALE=10

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Docker 配置
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
